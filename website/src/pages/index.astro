---
import { Code } from 'astro-expressive-code/components';
import '../styles/global.css';

const events = [
  { name: 'connect_document', direction: 'client -> server', purpose: 'Begin collaboration for a document.' },
  { name: 'connect_document_success', direction: 'server -> client', purpose: 'Acknowledge a successful document connection.' },
  { name: 'connect_document_error', direction: 'server -> client', purpose: 'Reject a document connection attempt.' },
  { name: 'submitOp', direction: 'client -> server', purpose: 'Submit operation messages for sequencing.' },
  { name: 'submitSignal', direction: 'client -> server', purpose: 'Send non-persistent collaboration signals.' },
  { name: 'op', direction: 'server -> client', purpose: 'Deliver sequenced operations back to clients.' },
  { name: 'signal', direction: 'server -> client', purpose: 'Deliver non-persistent collaboration signals.' },
  { name: 'nack', direction: 'server -> client', purpose: 'Reject submitted operations explicitly.' },
  { name: 'close', direction: 'connection', purpose: 'Close the document connection.' },
  { name: 'submitSummary', direction: 'client -> server', purpose: 'Submit a summary or snapshot for the document.' },
  { name: 'summaryAck', direction: 'server -> client', purpose: 'Acknowledge an accepted summary.' },
  { name: 'summaryNack', direction: 'server -> client', purpose: 'Reject a submitted summary.' }
];

const packageContents = [
  ['dewdrop/frame', 'Low-level Socket.IO event encoder/decoder for `42["event", ...args]`, plus ping/pong packet constants.'],
  ['dewdrop/events', 'Dependency-light Fluid event constants that protocol packages can import directly.'],
  ['dewdrop', 'Top-level helpers for common frames such as `connect_document`, `submitOp`, `submitSignal`, and inbound decode.'],
  ['dewdrop/server', 'A beryl server codec that decodes Fluid Socket.IO text frames and emits Fluid replies or pushes for beryl-based tests and servers.']
];

const examples = [
  {
    id: 'install-example',
    title: 'Add the git dependency',
    note: 'Until Hex publishing, pin the Git dependency explicitly.',
    language: 'toml',
    code: `[dependencies]
dewdrop = { git = "https://github.com/tylerbutler/dewdrop", ref = "main" }`
  },
  {
    id: 'encode-example',
    title: 'Encode an event packet',
    note: 'The event name and every argument stay positional.',
    language: 'gleam',
    code: `import dewdrop
import gleam/json

pub fn submit_frame() {
  dewdrop.encode_submit_op(
    json.string("c1"),
    json.preprocessed_array([]),
  )
}

// 42["submitOp","c1",[]]`
  },
  {
    id: 'decode-example',
    title: 'Decode an inbound event',
    note: 'Callers decode event arguments with their own schema after dewdrop splits the Socket.IO frame.',
    language: 'gleam',
    code: `import dewdrop

pub fn event_name() {
  let assert Ok(incoming) = dewdrop.decode(
    "42[\"op\",\"c1\",[]]",
  )

  incoming.event
}

// "op"`
  },
  {
    id: 'server-example',
    title: 'Use the server codec',
    note: 'beryl is used by `dewdrop/server` to adapt Fluid frames to beryl’s server codec interface.',
    language: 'gleam',
    code: `import beryl
import dewdrop/server

pub fn config() {
  beryl.config(server.server_codec())
}`
  }
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>dewdrop — Fluid protocol frames for Gleam</title>
    <meta name="description" content="dewdrop is a Gleam library for canonical Fluid Framework Socket.IO frames, event vocabulary, heartbeat packets, and server codec integration." />
    <link rel="icon" href="/dewdrop-icon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header" aria-label="Site header">
      <nav class="nav shell" aria-label="Main navigation">
        <a class="brand" href="#top" aria-label="dewdrop home">
          <img src="/dewdrop-icon.svg" width="40" height="40" alt="" />
          <span>dewdrop</span>
        </a>
        <div class="nav-links" aria-label="Page sections">
          <a href="#quickstart">Package</a>
          <a href="#frames">Frames</a>
          <a href="#events">Events</a>
          <a href="https://github.com/tylerbutler/dewdrop" target="_blank" rel="noreferrer" aria-label="Open dewdrop source on GitHub in a new tab">GitHub ↗</a>
        </div>
      </nav>
    </header>

    <main id="content">
      <section class="hero shell" id="top">
        <div class="hero-copy">
          <p class="context-line">Fluid Framework protocol codec for Gleam</p>
          <h1>Canonical Fluid Socket.IO frames for Gleam.</h1>
          <p class="hero-lede">dewdrop gives Gleam projects a precise Fluid wire vocabulary: event packets, positional arguments, heartbeat packets, event constants, and a beryl server codec.</p>
          <div class="hero-actions" aria-label="Primary actions">
            <a class="button primary" href="#quickstart">See the package</a>
            <a class="button secondary" href="https://github.com/tylerbutler/dewdrop" target="_blank" rel="noreferrer">View source ↗</a>
          </div>
        </div>

        <div class="protocol-panel" aria-label="Socket.IO frame anatomy">
          <div class="panel-topline">
            <span>packet</span>
            <code>42["submitOp", clientId, messages]</code>
          </div>
          <dl class="frame-map">
            <div>
              <dt>42</dt>
              <dd>Socket.IO event packet prefix</dd>
            </div>
            <div>
              <dt>submitOp</dt>
              <dd>Fluid event name</dd>
            </div>
            <div>
              <dt>clientId, messages</dt>
              <dd>positional arguments, kept in order</dd>
            </div>
          </dl>
          <ol class="state-line" aria-label="Frame lifecycle">
            <li>encoded</li>
            <li>decoded</li>
            <li>response encoded</li>
          </ol>
        </div>
      </section>

      <section class="section shell" id="quickstart" aria-labelledby="quickstart-title">
        <div class="section-heading">
          <h2 id="quickstart-title">What the package provides.</h2>
          <p>Add the pre-1.0 git dependency, encode and decode Fluid event packets, import the event vocabulary, and use the beryl server codec when tests need to speak the same wire shape.</p>
        </div>
        <div class="package-grid" aria-label="Gleam package examples">
          {examples.map((example) => (
            <article class="package-card">
              <div class="package-header">
                <div>
                  <h3>{example.title}</h3>
                  <p>{example.note}</p>
                </div>
              </div>
              <Code code={example.code} lang={example.language} title={example.title} />
            </article>
          ))}
        </div>
        <aside class="boundary-note" aria-label="beryl dependency role">
          <h3>Why beryl is a dependency</h3>
          <p><code>dewdrop/server</code> exposes a <code>beryl/wire/codec.Codec</code>. That lets beryl-based tests or servers decode Fluid Socket.IO text frames, derive a document topic from <code>connect_document</code>, and encode Fluid replies or pushes with the same <code>dewdrop/frame</code> wire format.</p>
        </aside>
      </section>

      <section class="section shell frame-section" id="frames" aria-labelledby="frames-title">
        <div class="section-heading compact">
          <h2 id="frames-title">The frame is the protocol boundary.</h2>
          <p>Fluid collaboration messages arrive as Socket.IO packets. dewdrop keeps the packet prefix, event name, and positional arguments visible.</p>
        </div>
        <div class="comparison" role="list" aria-label="Frame details">
          <article role="listitem">
            <h3>Event packet</h3>
            <code>42["event", ...args]</code>
            <p>The <code>42</code> prefix marks a Socket.IO event packet. The JSON array starts with the Fluid event name, followed by ordered arguments.</p>
          </article>
          <article role="listitem">
            <h3>Heartbeat packet</h3>
            <code>2</code>
            <p><code>dewdrop/frame</code> exposes ping and pong packet constants so callers and server tests can handle heartbeats outside event decoding.</p>
          </article>
        </div>
      </section>

      <section class="section shell" id="events" aria-labelledby="events-title">
        <div class="section-heading">
          <h2 id="events-title">Complete Fluid event vocabulary, ready to import.</h2>
          <p>The constants live in <code>dewdrop/events</code> so protocol packages can share names without pulling in a client or server runtime.</p>
        </div>
        <div class="event-table" role="table" aria-label="Fluid event vocabulary">
          <div class="event-row header" role="row">
            <span role="columnheader">Event</span>
            <span role="columnheader">Direction</span>
            <span role="columnheader">Purpose</span>
          </div>
          {events.map((event) => (
            <div class="event-row" role="row">
              <div class="event-cell" role="cell">
                <span class="cell-label">Event</span>
                <code>{event.name}</code>
              </div>
              <div class="event-cell" role="cell">
                <span class="cell-label">Direction</span>
                <span>{event.direction}</span>
              </div>
              <div class="event-cell" role="cell">
                <span class="cell-label">Purpose</span>
                <span>{event.purpose}</span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="section shell stack-section" aria-labelledby="stack-title">
        <div class="stack-copy">
          <h2 id="stack-title">A narrow protocol package.</h2>
          <p>dewdrop should make Fluid frames easy to encode, decode, name, and test from Gleam. It is not a broad collaboration framework.</p>
        </div>
        <div class="stack-list" aria-label="Package modules">
          {packageContents.map(([name, description]) => (
            <div class="stack-item">
              <strong>{name}</strong>
              <span>{description}</span>
            </div>
          ))}
        </div>
      </section>
    </main>

    <footer class="footer shell">
      <p>MIT licensed. Wire-frame behavior is canonical; the public API may change before 1.0.</p>
      <a href="https://github.com/tylerbutler/dewdrop" target="_blank" rel="noreferrer">github.com/tylerbutler/dewdrop ↗</a>
    </footer>
  </body>
</html>
