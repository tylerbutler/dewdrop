---
import '../styles/global.css';

const events = [
  { name: 'connect_document', direction: 'client -> server', purpose: 'Begin collaboration for a document.' },
  { name: 'connect_document_success', direction: 'server -> client', purpose: 'Acknowledge a successful join and carry the reply reference.' },
  { name: 'submitOp', direction: 'client -> server', purpose: 'Submit operation messages for sequencing.' },
  { name: 'op', direction: 'server -> client', purpose: 'Deliver sequenced operations back to clients.' },
  { name: 'submitSignal', direction: 'client -> server', purpose: 'Send non-persistent collaboration signals.' },
  { name: 'nack', direction: 'server -> client', purpose: 'Reject submitted operations explicitly.' }
];

const stack = [
  ['dewdrop', 'Fluid Socket.IO frames and event vocabulary.'],
  ['aquamarine', 'Channel client runtime that can plug in dewdrop as a codec.'],
  ['roost', 'Phoenix channel frame codec; intentionally not reused for Fluid.'],
  ['levee', 'Fluid server target for in-VM integration tests.']
];

const quickstart = `import dewdrop
import gleam/json

pub fn join_frame() {
  dewdrop.encode_connect(
    json.object([#("id", json.string("doc-123"))])
  )
}

// 42["connect_document",{"id":"doc-123"}]`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>dewdrop — Fluid protocol frames for Gleam</title>
    <meta name="description" content="dewdrop is a Gleam library for canonical Fluid Framework Socket.IO frames, event vocabulary, and aquamarine codec integration." />
    <link rel="icon" href="/dewdrop-icon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header" aria-label="Site header">
      <nav class="nav shell" aria-label="Main navigation">
        <a class="brand" href="#top" aria-label="dewdrop home">
          <img src="/dewdrop-icon.svg" width="40" height="40" alt="" />
          <span>dewdrop</span>
        </a>
        <div class="nav-links" aria-label="Page sections">
          <a href="#quickstart">Quickstart</a>
          <a href="#frames">Frames</a>
          <a href="#events">Events</a>
          <a href="https://github.com/tylerbutler/dewdrop">GitHub</a>
        </div>
      </nav>
    </header>

    <main id="content">
      <section class="hero shell" id="top">
        <div class="hero-copy">
          <p class="context-line">Fluid Framework protocol codec for Gleam</p>
          <h1>Canonical Socket.IO frames, without Phoenix-shaped assumptions.</h1>
          <p class="hero-lede">dewdrop gives Gleam clients a precise Fluid wire vocabulary: event packets, positional arguments, heartbeat handling, and an aquamarine codec boundary that stays honest about Socket.IO.</p>
          <div class="hero-actions" aria-label="Primary actions">
            <a class="button primary" href="#quickstart">Start with a frame</a>
            <a class="button secondary" href="https://github.com/tylerbutler/dewdrop">View source</a>
          </div>
        </div>

        <div class="protocol-panel" aria-label="Socket.IO frame anatomy">
          <div class="panel-topline">
            <span>packet</span>
            <code>42["submitOp", clientId, messages]</code>
          </div>
          <dl class="frame-map">
            <div>
              <dt>42</dt>
              <dd>Socket.IO event packet prefix</dd>
            </div>
            <div>
              <dt>submitOp</dt>
              <dd>Fluid event name</dd>
            </div>
            <div>
              <dt>clientId, messages</dt>
              <dd>positional arguments, kept in order</dd>
            </div>
          </dl>
          <div class="pulse-line" aria-hidden="true">
            <span></span><span></span><span></span><span></span>
          </div>
        </div>
      </section>

      <section class="section shell" id="quickstart" aria-labelledby="quickstart-title">
        <div class="section-heading">
          <h2 id="quickstart-title">Small API, exact output.</h2>
          <p>Encode Fluid events as the packets the canonical client expects. Decode inbound event packets without forcing them through a Phoenix tuple.</p>
        </div>
        <div class="code-layout">
          <pre aria-label="Gleam quickstart"><code>{quickstart}</code></pre>
          <div class="notes-list" aria-label="What dewdrop owns">
            <h3>What stays explicit</h3>
            <ul>
              <li>Fluid event names live in <code>dewdrop/events</code>.</li>
              <li>Socket.IO packets are encoded in <code>dewdrop/frame</code>.</li>
              <li>Dynamic args remain positional until callers decode their schema.</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="section shell frame-section" id="frames" aria-labelledby="frames-title">
        <div class="section-heading compact">
          <h2 id="frames-title">The frame is the product boundary.</h2>
          <p>roost models Phoenix channels. dewdrop models Fluid’s canonical Socket.IO shape.</p>
        </div>
        <div class="comparison" role="list" aria-label="Frame comparison">
          <article role="listitem">
            <h3>Fluid via dewdrop</h3>
            <code>42["event", ...args]</code>
            <p>Event name plus ordered arguments. No topic, no ref slot, no Phoenix join tuple.</p>
          </article>
          <article role="listitem">
            <h3>Phoenix via roost</h3>
            <code>[join_ref, ref, topic, event, payload]</code>
            <p>A five-part channel tuple with correlation fields built into the frame shape.</p>
          </article>
        </div>
      </section>

      <section class="section shell" id="events" aria-labelledby="events-title">
        <div class="section-heading">
          <h2 id="events-title">Fluid event vocabulary, ready to import.</h2>
          <p>The constants are dependency-free so downstream protocol packages can share names without pulling in a client runtime.</p>
        </div>
        <div class="event-table" role="table" aria-label="Fluid event vocabulary">
          <div class="event-row header" role="row">
            <span role="columnheader">Event</span>
            <span role="columnheader">Direction</span>
            <span role="columnheader">Purpose</span>
          </div>
          {events.map((event) => (
            <div class="event-row" role="row">
              <code role="cell">{event.name}</code>
              <span role="cell">{event.direction}</span>
              <span role="cell">{event.purpose}</span>
            </div>
          ))}
        </div>
      </section>

      <section class="section shell stack-section" aria-labelledby="stack-title">
        <div class="stack-copy">
          <h2 id="stack-title">Built for the Fluid/Gleam stack.</h2>
          <p>dewdrop is intentionally narrow. It should make a future in-VM levee integration client easier to test, not become a broad collaboration framework.</p>
        </div>
        <div class="stack-list" aria-label="Related packages">
          {stack.map(([name, description]) => (
            <div class="stack-item">
              <strong>{name}</strong>
              <span>{description}</span>
            </div>
          ))}
        </div>
      </section>
    </main>

    <footer class="footer shell">
      <p>MIT licensed. API unstable before 1.0.</p>
      <a href="https://github.com/tylerbutler/dewdrop">github.com/tylerbutler/dewdrop</a>
    </footer>
  </body>
</html>
