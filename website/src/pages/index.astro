---
import { Code } from 'astro-expressive-code/components';
import '../styles/global.css';

const events = [
  { name: 'connect_document', direction: 'client → server', purpose: 'Begin collaboration for a document.' },
  { name: 'connect_document_success', direction: 'server → client', purpose: 'Acknowledge a successful document connection.' },
  { name: 'connect_document_error', direction: 'server → client', purpose: 'Reject a document connection attempt.' },
  { name: 'submitOp', direction: 'client → server', purpose: 'Submit operation messages for sequencing.' },
  { name: 'submitSignal', direction: 'client → server', purpose: 'Send non-persistent collaboration signals.' },
  { name: 'op', direction: 'server → client', purpose: 'Deliver sequenced operations back to clients.' },
  { name: 'signal', direction: 'server → client', purpose: 'Broadcast non-persistent collaboration signals.' },
  { name: 'nack', direction: 'server → client', purpose: 'Reject submitted operations explicitly.' },
  { name: 'close', direction: 'either', purpose: 'Close the document connection.' },
  { name: 'submitSummary', direction: 'client → server', purpose: 'Submit a summary for the document.' },
  { name: 'summaryAck', direction: 'server → client', purpose: 'Acknowledge an accepted summary.' },
  { name: 'summaryNack', direction: 'server → client', purpose: 'Reject a submitted summary.' }
];

const layers = [
  { name: 'windsock', role: 'Socket.IO frame primitives', detail: 'Encodes and decodes raw text frames such as 42["event", ...args], plus Engine.IO heartbeat packets.' },
  { name: 'dewdrop', role: 'Fluid events and adapters', detail: 'Names the Fluid event vocabulary and exposes client/server codec adapters over the windsock frame shape.' },
  { name: 'spillway', role: 'Raw Fluid protocol model', detail: 'Owns protocol payloads, sequencing, sessions, JWT/auth, and domain types above event transport.' },
  { name: 'levee', role: 'Server runtime target', detail: 'Consumes the protocol layers to run Fluid-compatible collaboration services in Gleam.' }
];

const examples = [
  {
    id: 'install-example',
    step: 1,
    title: 'Add the git dependency',
    note: 'Until Hex publishing, pin the Git dependency explicitly.',
    language: 'toml',
    code: `[dependencies]
dewdrop = { git = "https://github.com/tylerbutler/dewdrop", ref = "main" }`
  },
  {
    id: 'encode-example',
    step: 2,
    title: 'Encode an event packet',
    note: 'The event name and every argument stay positional.',
    language: 'gleam',
    code: `import dewdrop
import gleam/json

pub fn connect_frame() {
  dewdrop.encode_connect(
    json.object([#("id", json.string("doc-123"))])
  )
}

// 42["connect_document",{"id":"doc-123"}]`
  },
  {
    id: 'submit-example',
    step: 3,
    title: 'Submit operations',
    note: 'Operation messages stay in the ordered argument list.',
    language: 'gleam',
    code: `import dewdrop
import gleam/json

pub fn submit_frame() {
  dewdrop.encode_submit_op(
    json.string("c1"),
    json.preprocessed_array([]),
  )
}

// 42["submitOp","c1",[]]`
  },
  {
    id: 'server-example',
    step: 4,
    title: 'Use the server codec',
    note: 'beryl can decode and encode the same Fluid event stream.',
    language: 'gleam',
    code: `import dewdrop/server

pub fn codec() {
  server.server_codec()
}`
  }
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>dewdrop - Fluid events and adapters for Gleam</title>
    <meta name="description" content="dewdrop is a Gleam library for Fluid Framework event vocabulary and client/server codec adapters over Socket.IO frames." />
    <link rel="icon" href="/dewdrop-logo.png" type="image/png" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header" aria-label="Site header">
      <nav class="nav shell" aria-label="Main navigation">
        <a class="brand" href="#top" aria-label="dewdrop home">
          <img src="/dewdrop-logo.png" width="33" height="40" alt="" />
          <span>dewdrop</span>
        </a>
        <div class="nav-links" aria-label="Page sections">
          <a href="#quickstart">Quickstart</a>
          <a href="#layers">Layers</a>
          <a href="#events">Events</a>
          <a href="https://github.com/tylerbutler/dewdrop" target="_blank" rel="noreferrer" aria-label="Open dewdrop source on GitHub in a new tab">GitHub →</a>
        </div>
      </nav>
    </header>

    <main id="content">
      <section class="hero shell" id="top">
        <div class="hero-copy">
          <p class="context-line">Fluid protocol surface for Gleam</p>
          <h1>Fluid event vocabulary, decoded from raw Socket.IO frames.</h1>
          <p class="hero-lede">dewdrop sits above raw Socket.IO frames and below the full Fluid protocol model. It names the canonical events, keeps their positional payloads visible, and gives client and server runtimes a narrow codec boundary.</p>
          <div class="hero-actions" aria-label="Primary actions">
            <a class="button primary" href="#install-example">Install from git</a>
            <a class="button secondary" href="https://github.com/tylerbutler/dewdrop" target="_blank" rel="noreferrer">View source →</a>
          </div>
        </div>

        <div class="hero-art">
          <div class="logo-plate" aria-label="dewdrop logo">
            <img src="/dewdrop-logo.png" width="445" height="544" alt="" />
            <p>Fluid events over exact Socket.IO frames.</p>
          </div>

          <div class="protocol-panel" aria-label="Dewdrop package boundary">
            <div class="panel-topline">
              <span>dewdrop boundary</span>
              <code>connect_document(payload) -> 42["connect_document", payload]</code>
            </div>
            <dl class="frame-map">
              <div>
                <dt>Fluid name</dt>
                <dd><code>connect_document</code> lives in <code>dewdrop/events</code>.</dd>
              </div>
              <div>
                <dt>Frame shape</dt>
                <dd><code>windsock</code> owns the raw <code>42[...]</code> packet.</dd>
              </div>
              <div>
                <dt>Runtime edge</dt>
                <dd>Client and server adapters translate events into codec messages.</dd>
              </div>
            </dl>
            <ol class="state-line" aria-label="Frame lifecycle">
              <li>encoded</li>
              <li>decoded</li>
              <li>response encoded</li>
            </ol>
          </div>
        </div>
      </section>

      <section class="section shell" id="quickstart" aria-labelledby="quickstart-title">
        <div class="section-heading">
          <h2 id="quickstart-title">Small API, exact output.</h2>
          <p>Add the pre-1.0 git dependency, encode and decode Fluid event packets, import the event vocabulary, and use the beryl server codec when tests need to speak the same wire shape.</p>
        </div>
        <ol class="package-grid" aria-label="Gleam package examples, in order">
          {examples.map((example) => (
            <li class={`package-card ${example.step === 1 ? 'primary' : ''}`} id={example.step === 1 ? example.id : undefined}>
              <article>
                <div class="package-header">
                  <span class="step-number">{example.step}</span>
                  <div>
                    <h3>{example.title}</h3>
                    <p>{example.note}</p>
                  </div>
                </div>
                <Code code={example.code} lang={example.language} title={example.title} />
              </article>
            </li>
          ))}
        </ol>
        <aside class="boundary-note" aria-label="beryl dependency role">
          <h3>Why beryl is a dependency</h3>
          <p><code>dewdrop/server</code> exposes a <code>beryl/wire/codec.Codec</code>. That lets beryl-based tests or servers decode Fluid Socket.IO text frames, derive a document topic from <code>connect_document</code>, and encode Fluid replies or pushes with <code>windsock</code>.</p>
        </aside>
      </section>

      <section class="section shell layer-section" id="layers" aria-labelledby="layers-title">
        <div class="section-heading compact">
          <h2 id="layers-title">The split is a stack, not a bigger package.</h2>
          <p>Each layer owns one kind of knowledge. Raw frame syntax, Fluid event names, protocol semantics, and server behavior stay separate.</p>
        </div>
        <div class="layer-map" role="list" aria-label="Fluid Gleam stack layers">
          {layers.map((layer) => (
            <article class={`layer-card ${layer.name === 'dewdrop' ? 'current' : ''}`} role="listitem">
              <span>{layer.name}</span>
              <h3>{layer.role}</h3>
              <p>{layer.detail}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section shell" id="events" aria-labelledby="events-title">
        <div class="section-heading">
          <h2 id="events-title">Complete Fluid event vocabulary, ready to import.</h2>
          <p>The constants live in <code>dewdrop/events</code> so protocol packages can share names without pulling in a client or server runtime.</p>
        </div>
        <div class="event-table-wrap">
          <table class="event-table" aria-label="Fluid event vocabulary">
            <thead>
              <tr class="event-row header">
                <th scope="col">Event</th>
                <th scope="col">Direction</th>
                <th scope="col">Purpose</th>
              </tr>
            </thead>
            <tbody>
              {events.map((event) => (
                <tr>
                  <td><code>{event.name}</code></td>
                  <td>{event.direction}</td>
                  <td>{event.purpose}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    </main>

    <footer class="footer shell">
      <p>MIT licensed. The public Gleam API may refine before 1.0, but the Fluid wire frames are canonical and safe to build on.</p>
      <a href="https://github.com/tylerbutler/dewdrop" target="_blank" rel="noreferrer">github.com/tylerbutler/dewdrop →</a>
    </footer>
  </body>
</html>
