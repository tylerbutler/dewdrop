---
import '../styles/global.css';

const events = [
  { name: 'connect_document', direction: 'client -> server', purpose: 'Begin collaboration for a document.' },
  { name: 'connect_document_success', direction: 'server -> client', purpose: 'Acknowledge a successful join.' },
  { name: 'connect_document_error', direction: 'server -> client', purpose: 'Reject a document connection attempt.' },
  { name: 'submitOp', direction: 'client -> server', purpose: 'Submit operation messages for sequencing.' },
  { name: 'op', direction: 'server -> client', purpose: 'Deliver sequenced operations back to clients.' },
  { name: 'submitSignal', direction: 'client -> server', purpose: 'Send non-persistent collaboration signals.' },
  { name: 'signal', direction: 'server -> client', purpose: 'Broadcast non-persistent collaboration signals.' },
  { name: 'nack', direction: 'server -> client', purpose: 'Reject submitted operations explicitly.' },
  { name: 'close', direction: 'either', purpose: 'Close a document connection.' },
  { name: 'submitSummary', direction: 'client -> server', purpose: 'Submit a summary for the document.' },
  { name: 'summaryAck', direction: 'server -> client', purpose: 'Acknowledge an accepted summary.' },
  { name: 'summaryNack', direction: 'server -> client', purpose: 'Reject a submitted summary.' }
];

const layers = [
  { name: 'windsock', role: 'Socket.IO frame primitives', detail: 'Encodes and decodes raw text frames such as 42["event", ...args], plus Engine.IO heartbeat packets.' },
  { name: 'dewdrop', role: 'Fluid events and adapters', detail: 'Names the Fluid event vocabulary and exposes client/server codec adapters over the windsock frame shape.' },
  { name: 'spillway', role: 'Raw Fluid protocol model', detail: 'Owns protocol payloads, sequencing, sessions, JWT/auth, and domain types above event transport.' },
  { name: 'levee', role: 'Server runtime target', detail: 'Consumes the protocol layers to run Fluid-compatible collaboration services in Gleam.' }
];

const quickstart = `import dewdrop
import gleam/json

pub fn connect_frame() {
  dewdrop.encode_connect(
    json.object([#("id", json.string("doc-123"))])
  )
}

// 42["connect_document",{"id":"doc-123"}]`;

const serverAdapter = `import dewdrop/server

pub fn codec() {
  server.server_codec()
}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>dewdrop — Fluid events and adapters for Gleam</title>
    <meta name="description" content="dewdrop is a Gleam library for Fluid Framework event vocabulary and client/server codec adapters over Socket.IO frames." />
    <link rel="icon" href="/dewdrop-icon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header" aria-label="Site header">
      <nav class="nav shell" aria-label="Main navigation">
        <a class="brand" href="#top" aria-label="dewdrop home">
          <img src="/dewdrop-icon.svg" width="40" height="40" alt="" />
          <span>dewdrop</span>
        </a>
        <div class="nav-links" aria-label="Page sections">
          <a href="#quickstart">Quickstart</a>
          <a href="#layers">Layers</a>
          <a href="#events">Events</a>
          <a href="https://github.com/tylerbutler/dewdrop">GitHub</a>
        </div>
      </nav>
    </header>

    <main id="content">
      <section class="hero shell" id="top">
        <div class="hero-copy">
          <p class="context-line">Fluid protocol surface for Gleam</p>
          <h1>Fluid event vocabulary, with adapters at the edge.</h1>
          <p class="hero-lede">dewdrop sits above raw Socket.IO frames and below the full Fluid protocol model. It names the canonical events, keeps their positional payloads visible, and gives client and server runtimes a narrow codec boundary.</p>
          <div class="hero-actions" aria-label="Primary actions">
            <a class="button primary" href="#quickstart">Inspect the boundary</a>
            <a class="button secondary" href="https://github.com/tylerbutler/dewdrop">View source</a>
          </div>
        </div>

        <div class="protocol-panel" aria-label="Dewdrop package boundary">
          <div class="panel-topline">
            <span>dewdrop boundary</span>
            <code>connect_document(payload) -> 42["connect_document", payload]</code>
          </div>
          <dl class="frame-map">
            <div>
              <dt>Fluid name</dt>
              <dd><code>connect_document</code> lives in <code>dewdrop/events</code>.</dd>
            </div>
            <div>
              <dt>Frame shape</dt>
              <dd><code>windsock</code> owns the raw <code>42[...]</code> packet.</dd>
            </div>
            <div>
              <dt>Runtime edge</dt>
              <dd>Client and server adapters translate events into codec messages.</dd>
            </div>
          </dl>
          <div class="pulse-line" aria-hidden="true">
            <span></span><span></span><span></span><span></span>
          </div>
        </div>
      </section>

      <section class="section shell" id="quickstart" aria-labelledby="quickstart-title">
        <div class="section-heading">
          <h2 id="quickstart-title">Small API, exact output.</h2>
          <p>Use dewdrop when the code needs to speak in Fluid events. Use windsock when the code only needs to parse or emit Socket.IO packet text.</p>
        </div>
        <div class="code-layout">
          <pre aria-label="Gleam client encoder example"><code>{quickstart}</code></pre>
          <div class="notes-list" aria-label="What dewdrop owns">
            <h3>What dewdrop owns</h3>
            <ul>
              <li>Fluid event constants in <code>dewdrop/events</code>.</li>
              <li>Common client encoders like <code>encode_connect</code> and <code>encode_submit_op</code>.</li>
              <li>Codec adapters that let client and server runtimes speak the same Fluid event stream.</li>
            </ul>
          </div>
        </div>
        <div class="adapter-strip" aria-label="Client and server adapter examples">
          <article>
            <h3>Client adapter</h3>
            <p><code>dewdrop.codec()</code> maps Fluid join/reply events onto a channel client codec.</p>
          </article>
          <article>
            <h3>Server adapter</h3>
            <pre aria-label="Gleam server codec example"><code>{serverAdapter}</code></pre>
          </article>
        </div>
      </section>

      <section class="section shell layer-section" id="layers" aria-labelledby="layers-title">
        <div class="section-heading compact">
          <h2 id="layers-title">The split is a stack, not a bigger package.</h2>
          <p>Each layer owns one kind of knowledge. Raw frame syntax, Fluid event names, protocol semantics, and server behavior stay separate.</p>
        </div>
        <div class="layer-map" role="list" aria-label="Fluid Gleam stack layers">
          {layers.map((layer) => (
            <article class={`layer-card ${layer.name === 'dewdrop' ? 'current' : ''}`} role="listitem">
              <span>{layer.name}</span>
              <h3>{layer.role}</h3>
              <p>{layer.detail}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section shell" id="events" aria-labelledby="events-title">
        <div class="section-heading">
          <h2 id="events-title">Fluid event vocabulary, ready to import.</h2>
          <p>The event catalog is dependency-light so protocol packages can share the same names without inheriting a transport client or server runtime.</p>
        </div>
        <div class="event-table" role="table" aria-label="Fluid event vocabulary">
          <div class="event-row header" role="row">
            <span role="columnheader">Event</span>
            <span role="columnheader">Direction</span>
            <span role="columnheader">Purpose</span>
          </div>
          {events.map((event) => (
            <div class="event-row" role="row">
              <code role="cell">{event.name}</code>
              <span role="cell">{event.direction}</span>
              <span role="cell">{event.purpose}</span>
            </div>
          ))}
        </div>
      </section>
    </main>

    <footer class="footer shell">
      <p>MIT licensed. API unstable before 1.0.</p>
      <a href="https://github.com/tylerbutler/dewdrop">github.com/tylerbutler/dewdrop</a>
    </footer>
  </body>
</html>
